# 环境变量示例
# ⚠️ 生产环境必须使用强随机密钥！
# 生成密钥: openssl rand -base64 64
NODE_ENV=development
PORT=3000

# CORS - 逗号分隔的允许域名，生产环境禁止使用 *
# 示例: CORS_ORIGIN=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGIN=http://localhost:5173

# JWT 密钥 - ⚠️ 必须使用强随机值 (至少64字符)
# 生成: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_random_64_char_string_MINIMUM

# JWT 有效期
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# 数据库
MONGODB_URI=mongodb://localhost:27017/stock_smart
REDIS_URL=redis://localhost:6379

# Stripe 支付
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# API Key 前缀
API_KEY_PREFIX=sk_stock_

# SMTP 邮件配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@stocksmart.com

# 市场数据
MARKET_DATA_API_KEY=your_market_data_api_key
MARKET_DATA_BASE_URL=https://api.market.example.com

# OpenAI API
OPENAI_API_KEY=sk-xxxxxxxxxxxxx
AI_MODEL=gpt-4
AI_MAX_TOKENS=4096

# 前端 URL (用于邮件链接等)
FRONTEND_URL=http://localhost:5173
