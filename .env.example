# 环境变量配置模板

# Server
NODE_ENV=development
PORT=3000
HOST=localhost

# JWT Secret (生产环境请使用强密码)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/minduniversity?retryWrites=true&w=majority
REDIS_URL=redis://localhost:6379

# Payment - Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Payment - 支付宝 (可选)
ALIPAY_APP_ID=...
ALIPAY_PRIVATE_KEY=...
ALIPAY_PUBLIC_KEY=...

# Payment - 微信支付 (可选)
WECHAT_APP_ID=...
WECHAT_MCH_ID=...
WECHAT_API_KEY=...

# AI API - OpenAI
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=https://api.openai.com/v1

# AI API - Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# AI API - 其他
HUGGINGFACE_API_KEY=...
COHERE_API_KEY=...

# Email (可选 - 用于发送通知)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=Mind University <noreply@minduniversity.com>

# CDN & Storage (可选)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=...
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# Analytics (可选)
GOOGLE_ANALYTICS_ID=UA-...
MIXPANEL_TOKEN=...

# Vercel (用于GitHub Actions)
VERCEL_TOKEN=...
VERCEL_ORG_ID=team_xxx
VERCEL_PROJECT_ID=prj_xxx

# Security
CORS_ORIGIN=https://minduniversity.com,https://www.minduniversity.com
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:3000/api
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_GOOGLE_ANALYTICS_ID=UA-...

# Feature Flags
ENABLE_STRIPE=true
ENABLE_WECHAT=false
ENABLE_ALIPAY=false
ENABLE_FREE_TIER=true
ENABLE_REGISTRATION=true
